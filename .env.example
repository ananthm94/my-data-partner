# Copy this file to .env and fill in your values.
# The .env file is gitignored — never commit your real key.

# Get your key at: https://console.anthropic.com/settings/keys
# Leave blank or omit to run without AI suggestions (the app still works).
ANTHROPIC_API_KEY=sk-ant-...

# Optional: override the session storage directory (default: /tmp/app_sessions)
# SESSION_DIR=/tmp/app_sessions
